% Sudoku puzzle solver by ASPuzzle
% Generated by aspalchemy 1.5.0

% ===== grid =====

% Define cells in the grid
cell(R, C) :- R = 1..6, C = 1..6.

% Define major lines in the grid
line("e", R, cell(R, C)) :- cell(R, C), R = 1..6.
line("s", C, cell(R, C)) :- cell(R, C), C = 1..6.


% ===== symbols =====

% Place symbols in the grid
{ number(cell(R, C), V) : V = 1..6 } = 1 :- cell(R, C).


% ===== Rules =====

% Each digit appears at most once in each row and column
:- number(Cell_1, N), number(Cell_2, N), line(D, Idx, Cell_1), line(D, Idx, Cell_2), Cell_1 != Cell_2.

% Define block membership
block(cell(R, C), N) :- cell(R, C), N = 1 + (C - 1) / 3 + 2 * ((R - 1) / 2).

% Each digit appears at most once in each block
:- number(Cell_1, N), number(Cell_2, N), block(Cell_1, Idx), block(Cell_2, Idx), Cell_1 != Cell_2.


% ===== Clues =====

number(cell(1, 1), 6).
number(cell(1, 2), 2).
number(cell(1, 4), 5).
number(cell(1, 6), 3).
number(cell(3, 1), 5).
number(cell(3, 5), 3).
number(cell(4, 2), 6).
number(cell(4, 5), 2).
number(cell(5, 4), 3).
number(cell(5, 5), 4).
number(cell(5, 6), 6).
number(cell(6, 1), 3).
number(cell(6, 3), 6).

