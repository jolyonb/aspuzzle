% ===== grid =====

% Define cells in the grid
cell(R, C) :- R = 1..10, C = 1..10.

% Define major lines in the grid
line("e", R, cell(R, C)) :- cell(R, C), R = 1..10.
line("s", C, cell(R, C)) :- cell(R, C), C = 1..10.

% Define directions in the grid
direction("n", cell(-1, 0)).
direction("ne", cell(-1, 1)).
direction("e", cell(0, 1)).
direction("se", cell(1, 1)).
direction("s", cell(1, 0)).
direction("sw", cell(1, -1)).
direction("w", cell(0, -1)).
direction("nw", cell(-1, -1)).

% Orthogonal directions
orthogonal_directions("n"; "e"; "s"; "w").

% Orthogonal adjacency definition
orthogonal(cell(R, C), cell(R + R_vec, C + C_vec)) :- orthogonal_directions(D), direction(D, cell(R_vec, C_vec)), cell(R, C), cell(R + R_vec, C + C_vec).

% Cell order chain
cell_order(cell(R, C), cell(R, C + 1)) :- R = 1..10, C = 1..9.
cell_order(cell(R, 10), cell(R + 1, 1)) :- R = 1..9.


% ===== Rules =====

% Define grid values

% Rule 1: No duplicated unshaded numbers in a line
:- line(D, Idx, C_w), value(C_w, N), #count{ C : white(C), value(C, N), line(D, Idx, C) } > 1.

% Rule 2: No adjacent black cells
:- orthogonal(cell(R, C), cell(R_adj, C_adj)), black(cell(R, C)), black(cell(R_adj, C_adj)).

% Rule 3: All white cells must be connected


