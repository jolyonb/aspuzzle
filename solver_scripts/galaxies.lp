% ===== regions =====

% Cell Status Assignment
{ connected(cell(R, C)) } = 1 :- cell(R, C).
anchor(C) :- center(C, _, _).
connected(C) :- anchor(C).

% Connection Rules
{ connects_to(C, N) : orthogonal(C, N) } :- connected(C).
connects_to(N, C) :- connects_to(C, N).

% Region Propagation
possible_region(cell(R, C), cell(R_anchor, C_anchor)) :- cell(R, C), anchor(cell(R_anchor, C_anchor)), center(cell(R_anchor, C_anchor), cell(R2, C2), _), R_anchor + R2 - R >= 1, R_anchor + R2 - R <= 15, C_anchor + C2 - C >= 1, C_anchor + C2 - C <= 15.
region(C, C) :- anchor(C).
region(N, A) :- connects_to(N, C), region(C, A), possible_region(N, A).
:- orthogonal(C, N), C < N, region(C, A), region(N, A), not connects_to(C, N).

% Integrity Constraints
:- cell(R, C), #count{ A : region(cell(R, C), A) } != 1.


% ===== Rules =====

% Symmetry rule
:- center(cell(R_1, C_1), cell(R_2, C_2), _), region(cell(R, C), cell(R_1, C_1)), not region(cell(R_1 + R_2 - R, C_1 + C_2 - C), cell(R_1, C_1)).

% Solution extraction
galaxy(Loc, Id) :- region(Loc, A), center(A, _, Id).

