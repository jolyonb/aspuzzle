% Shapeless Starbattle puzzle solver by ASPuzzle
% Generated by aspalchemy 1.5.2
#const star_count = 2.

% ===== grid =====

% Define cells in the grid
cell(R, C) :- R = 1..10, C = 1..10.

% Define major lines in the grid
line("e", R, cell(R, C)) :- cell(R, C), R = 1..10.
line("s", C, cell(R, C)) :- cell(R, C), C = 1..10.

% Define directions in the grid
direction("n", cell(-1, 0)).
direction("ne", cell(-1, 1)).
direction("e", cell(0, 1)).
direction("se", cell(1, 1)).
direction("s", cell(1, 0)).
direction("sw", cell(1, -1)).
direction("w", cell(0, -1)).
direction("nw", cell(-1, -1)).

% Vertex-sharing adjacency definition
vertex_sharing(cell(R, C), cell(R + R_vec, C + C_vec)) :- direction(_, cell(R_vec, C_vec)), cell(R, C), cell(R + R_vec, C + C_vec).


% ===== symbols =====

% Place symbols in the grid
0 { star(cell(R, C)) } 1 :- cell(R, C), not excluded(cell(R, C)).


% ===== Excluded cells =====

excluded(cell(2, 9)).
excluded(cell(4, 7)).
excluded(cell(5, 4)).
excluded(cell(5, 6)).
excluded(cell(6, 5)).
excluded(cell(6, 6)).
excluded(cell(7, 1)).
excluded(cell(7, 4)).
excluded(cell(7, 5)).
excluded(cell(7, 6)).
excluded(cell(7, 7)).
excluded(cell(7, 9)).
excluded(cell(7, 10)).
excluded(cell(8, 6)).
excluded(cell(9, 7)).
excluded(cell(9, 8)).
excluded(cell(10, 9)).


% ===== Rules =====

% Star placement rules
:- line(Dir, N, _), #count{ cell(R, C) : star(cell(R, C)), line(Dir, N, cell(R, C)) } != star_count.

% Star adjacency constraints
:- vertex_sharing(A, B), A < B, star(A), star(B).

#show.
#show star/1.
