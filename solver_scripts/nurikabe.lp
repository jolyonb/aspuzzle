% Nurikabe puzzle solver by ASPuzzle
% Generated by aspalchemy 1.5.2

% ===== grid =====

% Define cells in the grid
cell(R, C) :- R = 1..7, C = 1..7.

% Define directions in the grid
direction("n", cell(-1, 0)).
direction("ne", cell(-1, 1)).
direction("e", cell(0, 1)).
direction("se", cell(1, 1)).
direction("s", cell(1, 0)).
direction("sw", cell(1, -1)).
direction("w", cell(0, -1)).
direction("nw", cell(-1, -1)).

% Orthogonal directions
orthogonal_directions("n"; "e"; "s"; "w").

% Orthogonal adjacency definition
orthogonal(cell(R, C), cell(R + R_vec, C + C_vec)) :- orthogonal_directions(D), direction(D, cell(R_vec, C_vec)), cell(R, C), cell(R + R_vec, C + C_vec).

% Cell order chain
cell_order(cell(R, C), cell(R, C + 1)) :- R = 1..7, C = 1..6.
cell_order(cell(R, 7), cell(R + 1, 1)) :- R = 1..6.


% ===== Clues =====

% Define numbered islands
clue(cell(1, 1), 2).
clue(cell(1, 3), 3).
clue(cell(2, 7), 4).
clue(cell(3, 5), 1).
clue(cell(4, 6), 4).
clue(cell(6, 3), 2).
clue(cell(6, 5), 2).
clue(cell(7, 2), 5).


% ===== regions =====

% Cell Status Assignment
{ connected(cell(R, C)); regionless(cell(R, C)) } = 1 :- cell(R, C).
anchor(C) :- clue(C, _).
connected(C) :- anchor(C).

% Connection Rules
{ connects_to(C, N) : orthogonal(C, N), not regionless(N) } :- connected(C).
connects_to(N, C) :- connects_to(C, N).

% Region Propagation
possible_region(cell(R, C), cell(R_anchor, C_anchor)) :- cell(R, C), anchor(cell(R_anchor, C_anchor)), clue(cell(R_anchor, C_anchor), S), |R - R_anchor| + |C - C_anchor| < S.
region(C, C) :- anchor(C).
possible_region(C, C) :- anchor(C).
region(N, A) :- connects_to(N, C), region(C, A), possible_region(N, A).
:- orthogonal(C, N), C < N, region(C, A), region(N, A), not connects_to(C, N).
:- connects_to(C, N), region(C, A), not possible_region(N, A).

% Integrity Constraints
:- cell(R, C), not regionless(cell(R, C)), #count{ A : region(cell(R, C), A) } != 1.

% Forbid regionless pools

% Forbid 2x2 blocks of regionless
:- regionless(cell(R, C)), regionless(cell(R, C + 1)), regionless(cell(R + 1, C)), regionless(cell(R + 1, C + 1)), cell(R, C), cell(R + 1, C + 1).

% Regions cannot touch
:- region(C_1, A), orthogonal(C_1, C_2), not region(C_2, A), not regionless(C_2).

% Find anchor cell for regionless
regionless_anchor_seen(Cell) :- regionless(Cell).
regionless_anchor_seen(Cell) :- regionless_anchor_seen(Prev), cell_order(Prev, Cell).
regionless_anchor(Cell) :- regionless(Cell), cell_order(Prev, Cell), not regionless_anchor_seen(Prev).
regionless_anchor(Cell) :- regionless(Cell), cell_order(Cell, _), not cell_order(_, Cell).
:- regionless(Cell), not cell_order(Cell, _), not cell_order(_, Cell).

% Contiguity for regionless cells
connected_regionless(cell(R, C)) :- regionless_anchor(cell(R, C)).
connected_regionless(C_adj) :- connected_regionless(C), orthogonal(C, C_adj), regionless(C_adj).
:- regionless(C), not connected_regionless(C).


% ===== Rules =====

% Each island must have the correct size
:- clue(C, N), #count{ RegionSizeCell : region(RegionSizeCell, C) } != N.

% Size-1 islands must be fully surrounded by stream
regionless(C_adj) :- clue(C, 1), orthogonal(C, C_adj).

% Solution readout
stream(C) :- regionless(C).
island(C) :- region(C, _).

#show.
#show island/1.
#show stream/1.
