% Shikaku puzzle solver by ASPuzzle
% Generated by aspalchemy 1.5.2

% ===== grid =====

% Define cells in the grid
cell(R, C) :- R = 1..5, C = 1..5.


% ===== Clues =====

% Define the clued rectangle areas
clue(cell(1, 1), 2, 1).
clue(cell(1, 3), 3, 2).
clue(cell(2, 2), 4, 3).
clue(cell(2, 3), 2, 4).
clue(cell(3, 1), 4, 5).
clue(cell(3, 3), 2, 6).
clue(cell(3, 5), 2, 7).
clue(cell(4, 5), 2, 8).
clue(cell(5, 3), 2, 9).
clue(cell(5, 5), 2, 10).


% ===== Rules =====

% The shapes a clued area can take
shape(N, H, W) :- clue(_, N, _), H = 1..N, W = N / H, W * H = N, H <= 5, W <= 5.

% Every rectangle each clue could be
candidate(Idx, T, L, H, W) :- clue(cell(R, C), N, Idx), shape(N, H, W), T = R - H + 1..R, L = C - W + 1..C, T >= 1, L >= 1, T + H - 1 <= 5, L + W - 1 <= 5, #count{ cell(R_other, C_other) : clue(cell(R_other, C_other), _, _), R_other >= T, R_other <= T + H - 1, C_other >= L, C_other <= L + W - 1 } = 1.

% Each clue takes exactly one of its rectangles
{ placement(Idx, T, L, H, W) : candidate(Idx, T, L, H, W) } = 1 :- clue(_, _, Idx).

% A placed rectangle covers its cells
rectangle(cell(R, C), Idx) :- placement(Idx, T, L, H, W), R = T..T + H - 1, C = L..L + W - 1.

% The rectangles tile the grid
:- cell(R, C), not rectangle(cell(R, C), _).
:- rectangle(cell(R, C), Idx_1), rectangle(cell(R, C), Idx_2), Idx_1 < Idx_2.

#show.
#show rectangle/2.
