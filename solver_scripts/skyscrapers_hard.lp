% Skyscrapers puzzle solver by ASPuzzle
% Generated by aspalchemy 1.5.2

% ===== grid =====

% Define cells in the grid
cell(R, C) :- R = 1..6, C = 1..6.

% Define major lines in the grid
line("e", R, cell(R, C)) :- cell(R, C), R = 1..6.
line("s", C, cell(R, C)) :- cell(R, C), C = 1..6.

% Define ordered positions along orthogonal lines in the grid
line_of_sight("e", R, C, cell(R, C)) :- cell(R, C).
line_of_sight("w", R, 7 - C, cell(R, C)) :- cell(R, C).
line_of_sight("s", C, R, cell(R, C)) :- cell(R, C).
line_of_sight("n", C, 7 - R, cell(R, C)) :- cell(R, C).


% ===== Clues =====

% Clue constraints
clue("s", 4, 2).
clue("n", 2, 5).
clue("n", 3, 2).
clue("n", 6, 4).
clue("e", 6, 4).
clue("w", 2, 3).
clue("w", 5, 4).


% ===== symbols =====

% Place symbols in the grid
{ height(cell(R, C), V) : V = 1..6 } = 1 :- cell(R, C).


% ===== Rules =====

% Each height appears exactly once in each row and column
:- height(C_1, N), height(C_2, N), line(D, Idx, C_1), line(D, Idx, C_2), C_1 != C_2.

% Line-of-sight visibility
taller_before(Dir, Idx, Pos + 1, H) :- line_of_sight(Dir, Idx, Pos, cell(R, C)), height(cell(R, C), H), line_of_sight(Dir, Idx, Pos + 1, _).
taller_before(Dir, Idx, Pos + 1, H) :- taller_before(Dir, Idx, Pos, H), line_of_sight(Dir, Idx, Pos + 1, _).
taller_before(Dir, Idx, Pos, H - 1) :- taller_before(Dir, Idx, Pos, H), H > 1.
blocked(Dir, Idx, Pos) :- line_of_sight(Dir, Idx, Pos, cell(R, C)), height(cell(R, C), H), taller_before(Dir, Idx, Pos, H + 1).
visible(Dir, Idx, Pos) :- line_of_sight(Dir, Idx, Pos, _), not blocked(Dir, Idx, Pos).

% Visible count must match clue
:- clue(Dir, Idx, N), #count{ Pos : visible(Dir, Idx, Pos) } != N.

% Solver helpers: height bounds implied by a clue
height(cell(R, C), 6) :- clue(Dir, Idx, 1), line_of_sight(Dir, Idx, 1, cell(R, C)).
:- clue(Dir, Idx, N), line_of_sight(Dir, Idx, Pos, cell(R, C)), height(cell(R, C), H), H > 6 - N + Pos.


% ===== Given Heights =====

height(cell(1, 4), 2).
height(cell(3, 3), 1).

